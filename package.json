{
  "name": "noveum-ai-gateway",
  "version": "0.0.1",
  "description": "A hyper efficient, lightweight AI Gateway for edge deployment",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "dev:node": "tsx src/server.ts",
    "deploy": "wrangler deploy --minify",
    "test": "vitest",
    "lint": "eslint . --config eslint.config.js",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "build": "rollup -c",
    "start:node": "node build/server.js",
    "docker:build": "chmod +x scripts/build-docker.sh && ./scripts/build-docker.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.3.3",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "rollup": "^4.9.1",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1",
    "wrangler": "^3.88.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "gateway",
    "edge",
    "cloudflare",
    "workers",
    "openai",
    "anthropic",
    "bedrock"
  ],
  "author": "",
  "license": "MIT"
}
